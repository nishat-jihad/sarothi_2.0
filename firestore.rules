rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role, board, year, gender, mobile, recentlyWatched
    //
    // Collection: categories, groups, subjects, chapters, videos
    // Fields: Various metadata for educational content
    //
    // Collection: comments
    // Fields: videoId, userId, userName, userPhoto, text, likes, createdAt
    //
    // Collection: notifications
    // Fields: userId, type, message, read, createdAt
    //
    // Collection: activityLogs
    // Fields: adminId, adminName, action, details, createdAt
    //
    // Collection: reports
    // Fields: type, targetId, reporterId, reason, createdAt
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'] ||
          (request.auth.token.email == "alamnishat456@gmail.com" && request.auth.token.email_verified == true));
    }

    function isSuperAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin' ||
          (request.auth.token.email == "alamnishat456@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['user', 'admin', 'superadmin'];
    }

    function isValidComment(data) {
      return data.keys().hasAll(['videoId', 'userId', 'text', 'createdAt']) &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isOwner(uid) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == resource.data.role || isSuperAdmin()) || isSuperAdmin();
    }

    match /categories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /groups/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /subjects/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /chapters/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /videos/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /comments/{id} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidComment(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (request.resource.data.likes == resource.data.likes + 1 || request.resource.data.likes == resource.data.likes - 1) || isAdmin();
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /notifications/{id} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }

    match /activityLogs/{id} {
      allow read: if isSuperAdmin();
      allow create: if isAdmin();
    }

    match /reports/{id} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }
  }
}
