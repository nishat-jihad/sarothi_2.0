{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and metadata",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["superadmin", "admin", "user"] },
        "board": { "type": "string" },
        "year": { "type": "string" },
        "gender": { "type": "string" },
        "mobile": { "type": "string" },
        "recentlyWatched": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "email", "role"]
    },
    "Category": {
      "title": "Category",
      "description": "Educational category (HSC, SSC, Admission)",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Group": {
      "title": "Group",
      "description": "Group under a category (Science, Arts, Commerce)",
      "type": "object",
      "properties": {
        "categoryId": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["categoryId", "name"]
    },
    "Subject": {
      "title": "Subject",
      "description": "Subject under a group",
      "type": "object",
      "properties": {
        "groupId": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["groupId", "name"]
    },
    "Chapter": {
      "title": "Chapter",
      "description": "Chapter under a subject",
      "type": "object",
      "properties": {
        "subjectId": { "type": "string" },
        "name": { "type": "string" },
        "playlistUrl": { "type": "string" },
        "oneshotVideoId": { "type": "string" },
        "pdfUrl": { "type": "string" },
        "downloads": {
          "type": "object",
          "properties": {
            "360p": { "type": "string" },
            "480p": { "type": "string" },
            "720p": { "type": "string" }
          }
        }
      },
      "required": ["subjectId", "name"]
    },
    "Video": {
      "title": "Video",
      "description": "Individual video lesson",
      "type": "object",
      "properties": {
        "chapterId": { "type": "string" },
        "title": { "type": "string" },
        "youtubeId": { "type": "string" },
        "likes": { "type": "number" },
        "dislikes": { "type": "number" }
      },
      "required": ["chapterId", "title", "youtubeId"]
    },
    "Comment": {
      "title": "Comment",
      "description": "User comment on a video",
      "type": "object",
      "properties": {
        "videoId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "text": { "type": "string" },
        "likes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["videoId", "userId", "text", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Real-time user notification",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "message", "createdAt"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "Admin activity log",
      "type": "object",
      "properties": {
        "adminId": { "type": "string" },
        "adminName": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["adminId", "action", "createdAt"]
    },
    "Report": {
      "title": "Report",
      "description": "Content report",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "targetId": { "type": "string" },
        "reporterId": { "type": "string" },
        "reason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "targetId", "reporterId", "reason", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/categories/{categoryId}": { "schema": "Category", "description": "Educational categories" },
    "/groups/{groupId}": { "schema": "Group", "description": "Groups under categories" },
    "/subjects/{subjectId}": { "schema": "Subject", "description": "Subjects under groups" },
    "/chapters/{chapterId}": { "schema": "Chapter", "description": "Chapters under subjects" },
    "/videos/{videoId}": { "schema": "Video", "description": "Videos under chapters" },
    "/comments/{commentId}": { "schema": "Comment", "description": "Video comments" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications" },
    "/activityLogs/{logId}": { "schema": "ActivityLog", "description": "Admin activity logs" },
    "/reports/{reportId}": { "schema": "Report", "description": "Content reports" }
  }
}
